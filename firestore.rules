
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- GLOBAL HELPER FUNCTIONS ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid));
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function getUserData(userId) {
      return get(/databases/$(database)/documents/users/$(userId)).data;
    }

    function isTaskMember(taskData) {
      let userData = getUserData(request.auth.uid);
      return isSignedIn() && (
        taskData.assignedDeveloperId == request.auth.uid || 
        taskData.assignedClientId == request.auth.uid ||
        (taskData.assignedTeamId != null && taskData.assignedTeamId == userData.teamId)
      );
    }

    // --- COLLECTION RULES ---

    match /users/{userId} {
      allow get: if isSignedIn();
      allow list: if isAdmin();
      allow create: if isAdmin() || (
        isOwner(userId) && 
        request.resource.data.email == 'admin@crm.com' && 
        request.resource.data.role == 'Admin'
      );
      allow update: if isAdmin() || isOwner(userId);
      allow delete: if isAdmin();
    }

    match /roles_admin/{adminId} {
      allow get: if isSignedIn();
      allow list: if isAdmin();
      allow create: if isAdmin() || (
        request.auth.uid == adminId && 
        get(/databases/$(database)/documents/users/$(adminId)).data.email == 'admin@crm.com'
      );
      allow update, delete: if isAdmin();
    }

    match /teams/{teamId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /tasks/{taskId} {
      allow list: if isSignedIn();
      allow get: if isAdmin() || isTaskMember(resource.data);
      allow create: if isAdmin();
      allow update: if resource != null && (isAdmin() || (
                      getUserData(request.auth.uid).role == 'Developer' && 
                      (resource.data.assignedDeveloperId == request.auth.uid || 
                       resource.data.assignedTeamId == getUserData(request.auth.uid).teamId)
                    ));
      allow delete: if resource != null && isAdmin();
    }

    match /tasks/{taskId}/comments/{commentId} {
      function getParentTask() {
        return get(/databases/$(database)/documents/tasks/$(taskId)).data;
      }
      allow list: if isAdmin() || isTaskMember(getParentTask());
      allow get: if isAdmin() || isTaskMember(getParentTask());
      allow create: if (isAdmin() || isTaskMember(getParentTask())) && request.resource.data.userId == request.auth.uid;
      allow update: if resource != null && (isAdmin() || isOwner(resource.data.userId));
      allow delete: if resource != null && (isAdmin() || isOwner(resource.data.userId));
    }
  }
}
