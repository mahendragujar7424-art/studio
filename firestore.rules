
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * CRM SECURITY RULES PHILOSOPHY
     * Restricted Access: Registration is only possible by an Admin.
     */

    // --- GLOBAL HELPER FUNCTIONS ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid));
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function getUserData(userId) {
      return get(/databases/$(database)/documents/users/$(userId)).data;
    }

    function isTaskMember(taskData) {
      return isSignedIn() && (
        taskData.assignedDeveloperId == request.auth.uid || 
        taskData.assignedClientId == request.auth.uid
      );
    }

    // --- COLLECTION RULES ---

    match /users/{userId} {
      allow get: if isSignedIn();
      allow list: if isAdmin();
      // Only Admins can create new user profiles now.
      allow create: if isAdmin();
      allow update: if isAdmin() || isOwner(userId);
      allow delete: if isAdmin();
    }

    match /roles_admin/{adminId} {
      allow get, list, create, update, delete: if isAdmin();
    }

    match /tasks/{taskId} {
      allow list: if isAdmin() || isSignedIn();
      
      allow get: if isAdmin() || isTaskMember(resource.data);
      
      allow create: if (isAdmin() || getUserData(request.auth.uid).role == 'Developer') 
                    && request.resource.data.createdById == request.auth.uid;
      
      allow update: if resource != null && (isAdmin() || (
                      getUserData(request.auth.uid).role == 'Developer' && 
                      resource.data.assignedDeveloperId == request.auth.uid
                    )) && request.resource.data.createdById == resource.data.createdById;
      
      allow delete: if resource != null && isAdmin();
    }

    match /tasks/{taskId}/comments/{commentId} {
      function getParentTask() {
        return get(/databases/$(database)/documents/tasks/$(taskId)).data;
      }

      allow list: if isAdmin() || isTaskMember(getParentTask());
      
      allow get: if isAdmin() || isTaskMember(getParentTask());
      
      allow create: if (isAdmin() || isTaskMember(getParentTask())) 
                    && request.resource.data.userId == request.auth.uid;
      
      allow update: if resource != null && (isAdmin() || isOwner(resource.data.userId))
                    && request.resource.data.userId == resource.data.userId;
      
      allow delete: if resource != null && (isAdmin() || isOwner(resource.data.userId));
    }
  }
}
