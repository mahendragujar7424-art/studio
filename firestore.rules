
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- GLOBAL HELPER FUNCTIONS ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid));
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function getUserData(userId) {
      let path = /databases/$(database)/documents/users/$(userId);
      return exists(path) ? get(path).data : null;
    }

    function isTaskMember(taskData) {
      if (!isSignedIn() || taskData == null) return false;
      let uid = request.auth.uid;
      
      // Prioritize fast, direct assignment checks
      if (taskData.assignedDeveloperId == uid || taskData.assignedClientId == uid) {
        return true;
      }
      
      // Fallback to team check if applicable
      if (taskData.assignedTeamId != null) {
        let profile = getUserData(uid);
        return profile != null && profile.teamId == taskData.assignedTeamId;
      }
      
      return false;
    }

    function isDeveloper() {
      let profile = getUserData(request.auth.uid);
      return profile != null && profile.role == 'Developer';
    }

    function isClient() {
      let profile = getUserData(request.auth.uid);
      return profile != null && profile.role == 'Client';
    }

    // --- COLLECTION RULES ---

    match /users/{userId} {
      allow get: if isSignedIn();
      // Allow listing if the user is an admin, OR if any member is filtering for the Developer directory
      allow list: if isAdmin() || (isSignedIn() && request.query.filters.role == 'Developer');
      allow create: if isAdmin() || (
        isOwner(userId) && 
        request.resource.data.email == 'admin@crm.com' && 
        request.resource.data.role == 'Admin'
      );
      allow update: if isAdmin() || isOwner(userId);
      allow delete: if isAdmin();
    }

    match /roles_admin/{adminId} {
      allow get: if isSignedIn();
      allow list: if isAdmin();
      allow create: if isAdmin() || (
        request.auth.uid == adminId && 
        get(/databases/$(database)/documents/users/$(adminId)).data.email == 'admin@crm.com'
      );
      allow update, delete: if isAdmin();
    }

    match /teams/{teamId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /tasks/{taskId} {
      allow list: if isSignedIn();
      allow get: if isAdmin() || isTaskMember(resource.data);
      allow create: if isAdmin();
      allow update: if resource != null && (
                      isAdmin() || 
                      (isDeveloper() && isTaskMember(resource.data)) ||
                      (isClient() && isTaskMember(resource.data))
                    );
      allow delete: if resource != null && isAdmin();
    }

    match /tasks/{taskId}/comments/{commentId} {
      function getParentTask() {
        let path = /databases/$(database)/documents/tasks/$(taskId);
        return exists(path) ? get(path).data : null;
      }
      
      function canAccessComments() {
        let parentTask = getParentTask();
        return parentTask != null && (isAdmin() || isTaskMember(parentTask));
      }

      allow list, get: if isSignedIn() && canAccessComments();
      allow create: if isSignedIn() && canAccessComments() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if resource != null && (isAdmin() || isOwner(resource.data.userId));
    }

    match /work_updates/{updateId} {
      allow get: if isSignedIn() && (
        isAdmin() || 
        resource.data.developerId == request.auth.uid || 
        resource.data.clientId == request.auth.uid
      );
      
      allow list: if isSignedIn() && (
        isAdmin() || 
        (isDeveloper() && request.query.filters.developerId == request.auth.uid) ||
        (isClient() && request.query.filters.clientId == request.auth.uid)
      );

      allow create: if isSignedIn() && isDeveloper();
      allow update, delete: if isAdmin();
    }
  }
}
