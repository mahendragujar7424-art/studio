
{
  "entities": {
    "User": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "User",
      "type": "object",
      "description": "Represents an application user with different roles and associated metadata.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the User entity."
        },
        "name": {
          "type": "string",
          "description": "The full name of the user."
        },
        "email": {
          "type": "string",
          "description": "The unique email address of the user.",
          "format": "email"
        },
        "role": {
          "type": "string",
          "description": "The role of the user within the application (e.g., Admin, Developer, Client). Possible values: 'Admin', 'Developer', 'Client'."
        },
        "teamId": {
          "type": "string",
          "description": "Reference to the Team this user (Developer) belongs to."
        },
        "assignedDeveloperId": {
          "type": "string",
          "description": "Reference to the User (Developer role) who is assigned to this client."
        },
        "createdAt": {
          "type": "string",
          "description": "Timestamp when the user account was created.",
          "format": "date-time"
        },
        "updatedAt": {
          "type": "string",
          "description": "Timestamp when the user account was last updated.",
          "format": "date-time"
        }
      },
      "required": [
        "id",
        "name",
        "email",
        "role",
        "createdAt",
        "updatedAt"
      ]
    },
    "Team": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Team",
      "type": "object",
      "description": "Represents a team within the organization.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the Team."
        },
        "name": {
          "type": "string",
          "description": "The name of the team."
        },
        "description": {
          "type": "string",
          "description": "A brief description of the team's purpose (Project Name)."
        },
        "developerIds": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Array of user IDs for developers assigned to this team."
        },
        "createdAt": {
          "type": "string",
          "description": "Timestamp of creation.",
          "format": "date-time"
        }
      },
      "required": ["id", "name", "createdAt"]
    },
    "Task": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Task",
      "type": "object",
      "description": "Represents a specific task within the CRM.",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "status": { "type": "string" },
        "progress": { "type": "number" },
        "priority": { "type": "string" },
        "assignedDeveloperId": { "type": "string" },
        "assignedTeamId": { "type": "string" },
        "assignedClientId": { "type": "string" },
        "createdById": { "type": "string" },
        "dueDate": { "type": "string", "format": "date" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "title", "status", "assignedClientId", "createdById", "createdAt", "updatedAt"]
    },
    "Comment": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Comment",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "taskId": { "type": "string" },
        "message": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "userId", "taskId", "message", "timestamp"]
    }
  },
  "auth": {
    "providers": [
      "password"
    ]
  },
  "firestore": {
    "structure": [
      {
        "path": "/users/{userId}",
        "definition": {
          "entityName": "User",
          "schema": { "$ref": "#/backend/entities/User" },
          "description": "User profiles with role-based metadata."
        }
      },
      {
        "path": "/roles_admin/{adminId}",
        "definition": {
          "entityName": "AdminRole",
          "schema": { "$ref": "#/backend/entities/User" },
          "description": "Admin privileges marker."
        }
      },
      {
        "path": "/teams/{teamId}",
        "definition": {
          "entityName": "Team",
          "schema": { "$ref": "#/backend/entities/Team" },
          "description": "Collection of organizational teams."
        }
      },
      {
        "path": "/tasks/{taskId}",
        "definition": {
          "entityName": "Task",
          "schema": { "$ref": "#/backend/entities/Task" },
          "description": "CRM tasks."
        }
      },
      {
        "path": "/tasks/{taskId}/comments/{commentId}",
        "definition": {
          "entityName": "Comment",
          "schema": { "$ref": "#/backend/entities/Comment" },
          "description": "Task comments."
        }
      }
    ]
  }
}
